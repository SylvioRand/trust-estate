JWT_SECRET_PRIVATE_KEY=../../secret/jwtTokenService/jwt_auth_private.key
JWT_SECRET_PUBLIC_KEY=../../secret/jwtTokenService/jwt_auth_public.pem
# ==============================================
# DATABASE
# ==============================================
