#=================================== LLM config =======================================

# ========= Github models ===========
# LLM_API_URL=https://models.inference.ai.azure.com/chat/completions
# LLM_API_KEY=Your API key
# LLM_MODEL=gpt-4o or any other model you want, you can separate model by coma

# ================================= Groq models ===========================
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=our API key
LLM_MODEL=openai/gpt-oss-120b,llama-3.3-70b-versatile,llama-3.1-8b-instant

# ================================== Embedding ==========================
EMBEDDING_MODEL=your_embedding_model
#Examples
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_MODEL=all-MiniLM-L6-v2


INTERNAL_KEY_SECRET=Your internal key
