# ==============================================
# Trust Estate - Environment Variables
# ==============================================
# Copy this file to .env and fill in the values

# ==============================================
# DATABASE
# ==============================================
POSTGRES_USER=trustestate
POSTGRES_PASSWORD=trustestate_secret
POSTGRES_DB=trustestate
DATABASE_URL=postgresql://trustestate:trustestate_secret@db:5432/trustestate

# ==============================================
# AUTH SERVICE - JWT
# ==============================================
# JWT keys are mounted as files from ./secret/jwtTokenService/
# Generate with: openssl genrsa -out jwt_auth_private.key 2048
#                openssl rsa -in jwt_auth_private.key -pubout -out jwt_auth_public.pem
JWT_REFRESH_SECRET=JWT_REFRESH_SECRET

# ==============================================
# AUTH SERVICE - Google OAuth
# ==============================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
REDIRECT_URI=https://localhost:8443/api/auth/google/callback
AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
TOKEN_URL=https://oauth2.googleapis.com/token
USER_INFO_URL=https://www.googleapis.com/oauth2/v2/userinfo

# ==============================================
# AUTH SERVICE - Email (Gmail)
# ==============================================
# Get app password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# ==============================================
# AUTH SERVICE - App Config
# ==============================================
COOKIE_SECRET=COOKIE_SECRET
FRONTEND_URL=https://localhost:8443

# ==============================================
# AI & LLM CONFIGURATION
# ==============================================
#=========== Groq models ===============
LLM_API_KEY=your_groq_API_key
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=openai/gpt-oss-120b, llama-3.3-70b-versatile, llama-3.1-8b-instant, meta-llama/llama-4-scout-17b-16e-instruct

#======== Chromadb config =========
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2


# ==============================================
# INTERNAL SERVICE COMMUNICATION
# ==============================================
# Shared secret between microservices (e.g., Auth and Listings)
INTERNAL_KEY_SECRET=INTERNAL_KEY_SECRET
